# --- Auth ---
JWT_SECRET=            # long random string, e.g. `openssl rand -hex 32`
ADMIN_KEY=              # a password only you know, used to create employee logins

# --- Database ---
DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Email (currently Gmail) ---
# Gmail requires an "App Password", not your normal password:
#   1. Turn on 2-Step Verification on the Google account: myaccount.google.com/security
#   2. Go to myaccount.google.com/apppasswords
#   3. Create one for "Mail" / "Other (Time Clock)" and use the 16-character
#      code below as SMTP_PASS. Regular Gmail passwords will be rejected.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=              # the 16-char app password, not your login password
SMTP_FROM=you@gmail.com

# Where submitted timesheets land (can be the same as SMTP_USER, or a
# separate payroll inbox)
PAYROLL_EMAIL=you@gmail.com

# --- Switching providers later ---
# Moving to another address or a transactional provider (Postmark,
# SendGrid, Amazon SES, your own domain's mail server, etc.) only means
# updating SMTP_HOST/PORT/USER/PASS above — mailer.js doesn't change.
# Two things worth knowing when that day comes:
#   - Gmail caps outgoing mail around 500/day on a free account, which is
#     irrelevant at your team size but worth knowing if that ever changes.
#   - Gmail SMTP can be flaky about deliverability for automated/bulk mail
#     over time; a dedicated provider like Postmark is more reliable if
#     you're sending from a business domain.
